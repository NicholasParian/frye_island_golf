# Put this file at the repo root as `.env` (recommended) or copy vars into `apps/api/.env`.
# Root `npm run db:*` loads root `.env` then `apps/api/.env` (API dev server loads the same pair).

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frye_island_golf?schema=public"

# API
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed admin (optional; used by prisma/seed.ts)
ADMIN_EMAIL=admin@fryeislandgolf.local
ADMIN_PASSWORD=change-me-admin-password

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public URL of the web app (for Stripe redirects)
WEB_APP_URL=http://localhost:5173

# Subpath on the public host (e.g. /fryeIslandGolf for https://www.xraes.com/fryeIslandGolf). Leave empty for local root.
# For local subpath dev, set the same in .env and VITE_PUBLIC_PATH_PREFIX so Vite matches.
PUBLIC_PATH_PREFIX=
VITE_PUBLIC_PATH_PREFIX=

# On small cloud VMs (e.g. 2 vCPU / 8 GB), building api + web at once can OOM: npm may die with
# "Exit handler never called". Build sequentially, then up:
#   docker compose build api && docker compose build web && docker compose up -d
#
# --- Docker Compose (copy to .env next to docker-compose.yml) ---
# JWT_ACCESS_SECRET=long-random-string-at-least-32-chars
# JWT_REFRESH_SECRET=another-long-random-string-32-chars
# CORS_ORIGIN=http://localhost:8080
# WEB_APP_URL=http://localhost:8080
# WEB_PORT=8080
# Then: docker compose up --build
# App: http://localhost:8080  (nginx → static UI + /v1 → API)
# Seed admin (from host, DB exposed on 5432):
#   cd apps/api && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frye_island_golf?schema=public JWT_ACCESS_SECRET=... JWT_REFRESH_SECRET=... npx tsx prisma/seed.ts

# --- Production: https://www.xraes.com/fryeIslandGolf (Caddy in proxy_service + xraes_proxy network) ---
# Network model: `db` and `api` use only the private bridge `frye_island_golf` (no name/DNS collision with other
# subprojects). Only `web` also joins `xraes_proxy` so Caddy can reach nginx; Postgres and the API are not on the edge network.
# 1. On the host: start the edge proxy (see xraes/proxy_service) so network `xraes_proxy` exists and Caddy binds 80/443.
# 2. In .env next to docker-compose.yml:
#   JWT_ACCESS_SECRET=       (long random, 32+ chars)
#   JWT_REFRESH_SECRET=      (different long random)
#   CORS_ORIGIN=https://www.xraes.com
#   WEB_APP_URL=https://www.xraes.com/fryeIslandGolf
#   PUBLIC_PATH_PREFIX=/fryeIslandGolf
#   WEB_PORT=8080            (optional: omit or set 0:0 to not publish; Caddy hits web on `frye-web:80` on xraes_proxy)
# 3. Do not publish Postgres in production: remove the db `ports: 5432:5432` mapping.
# Stripe Dashboard → live webhook URL (path includes the subpath + /v1):
#   https://www.xraes.com/fryeIslandGolf/v1/webhooks/stripe
# Legacy Caddy-to-localhost example: docker/www.xraes.com.Caddyfile.example
# CI: GitHub Actions → .github/workflows/deploy-www-xraes.yml (set repo secrets, then Run workflow)
